{
  "name": "vscode-markit",
  "publisher": "earlytexts",
  "displayName": "Markit (Early Texts)",
  "version": "2.0.0",
  "repository": {
    "url": "https://github.com/earlytexts/markit"
  },
  "icon": "./markit-logo.png",
  "description": "Language support for the Markit markup language",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/client.js",
  "files": [
    "dist",
    "media",
    "syntaxes/markit.tmLanguage.json",
    "snippets/markit.json",
    "language-configuration.json",
    "markit-logo.png",
    "LICENSE.md",
    "README.md"
  ],
  "contributes": {
    "languages": [
      {
        "id": "markit",
        "aliases": [
          "Markit",
          "markit"
        ],
        "extensions": [
          ".mit"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "markit",
        "scopeName": "source.markit",
        "path": "./syntaxes/markit.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "markit",
        "path": "./snippets/markit.json"
      }
    ],
    "commands": [
      {
        "command": "markit.showPreview",
        "title": "Markit: Open Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "markit.compileToHTML",
        "title": "Markit: Compile to HTML"
      },
      {
        "command": "markit.compileToJSON",
        "title": "Markit: Compile to JSON"
      },
      {
        "command": "markit.compileToText",
        "title": "Markit: Compile to Text"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markit.showPreview",
          "when": "editorLangId == markit",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "markit.showPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markit"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:watch": "node esbuild.mjs --watch",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies --out build/vscode-markit.vsix"
  },
  "dependencies": {
    "markit": "file:..",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
